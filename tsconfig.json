{
  "exclude": [
    "test",
    "test-e2e",
    "lib",
    "node_modules"
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "target": "es2022",
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "./lib",
    "sourceRoot": "./src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "pretty": true,
    "allowJs": true,
    "checkJs": true,
    "lib": [
      "es2022"
    ],
    "types": [
      "node"
    ]
  }
}
